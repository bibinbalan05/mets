@inherits LayoutComponentBase

<MudThemeProvider IsDarkMode="true" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIcon Icon="@Icons.Material.Filled.Factory" Class="mr-3" />
        <MudText Typo="Typo.h6">METS</MudText>
        <MudSpacer />
        <MudStack Row="true" Spacing="1" Class="align-center">
            <NavLink class="mud-nav-link" href="/" Match="NavLinkMatch.All">Dashboard</NavLink>
        <NavLink class="mud-nav-link" href="/request/new">New Request</NavLink>
        </MudStack>
    </MudAppBar>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="my-4 pt-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<style>
    .mud-nav-link {
        color: white;
        text-decoration: none;
        padding: 6px 16px;
        border-radius: 4px;
        font-size: 0.875rem;
        font-weight: 500;
        letter-spacing: 0.02857em;
        text-transform: uppercase;
        transition: background-color 0.2s;
        display: inline-flex;
        align-items: center;
    }
    .mud-nav-link:hover {
        background-color: rgba(255, 255, 255, 0.1);
    }
</style>

