@page "/request/{Id:guid}"
@implements IDisposable
@inject HttpClient Http
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

@if (_request == null)
{
    <div style="display: flex; align-items: center; justify-content: center; min-height: 400px; width: 100%;">
        <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
    </div>
}
else
{
    <MudGrid>
        <MudItem xs="12" md="8">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h5">Request Details</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip T="string" Color="@GetStatusColor(_request.Status)">@_request.Status.ToString()</MudChip>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudText><b>Location:</b> @_request.Location</MudText>
                    <MudText><b>Created By:</b> @_request.CreatedBy</MudText>
                    @if (!string.IsNullOrEmpty(_request.ReviewedBy))
                    {
                        <MudText><b>Reviewed By:</b> @_request.ReviewedBy</MudText>
                    }
                    <MudText><b>Priority:</b> @_request.Priority</MudText>
                    <MudText><b>Created At:</b> @_request.CreatedAt.ToString("g")</MudText>
                    
                    @if (_request.Status == RequestStatus.Rejected)
                    {
                        <MudAlert Severity="Severity.Error" Class="mt-2">Rejection Reason: @_request.RejectionReason</MudAlert>
                    }

                    @if (_request.ValidationStatus == ValidationStatus.Pending)
                    {
                        <MudAlert Severity="Severity.Info" Class="mt-2">
                            <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="mr-2" />
                            Validating stock availability... (Polling every 2 seconds)
                        </MudAlert>
                    }
                    else if (_request.ValidationStatus == ValidationStatus.Completed)
                    {
                        <MudAlert Severity="Severity.Success" Class="mt-2">Stock validation completed.</MudAlert>
                    }
                    
                    <MudTable Items="@_request.Items" Dense="true" Class="mt-4">
                        <HeaderContent>
                            <MudTh>Article Number</MudTh>
                            <MudTh>Description</MudTh>
                            <MudTh>Requested Qty</MudTh>
                            <MudTh>Available Stock</MudTh>
                            <MudTh>Fulfilled Qty</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Article Number">@context.ArticleNumber</MudTd>
                            <MudTd DataLabel="Description">@context.Description</MudTd>
                            <MudTd DataLabel="Requested Qty">@context.RequestedQuantity</MudTd>
                            <MudTd DataLabel="Available Stock">
                                @if(context.StockAvailable.HasValue)
                                {
                                    <MudChip T="string" Color="@(context.StockAvailable >= context.RequestedQuantity ? Color.Success : Color.Warning)" Size="Size.Small">
                                        @context.StockAvailable
                                    </MudChip>
                                }
                                else
                                {
                                    <MudText Typo="Typo.body2">-</MudText>
                                }
                            </MudTd>
                            <MudTd DataLabel="Fulfilled Qty">
                                @if (_request.Status == RequestStatus.Approved && _isFulfilling)
                                {
                                    <MudNumericField @bind-Value="context.FulfilledQuantity" Min="1" Max="@context.RequestedQuantity" HideSpinButtons="true" />
                                }
                                else
                                {
                                    @context.FulfilledQuantity
                                }
                            </MudTd>
                        </RowTemplate>
                    </MudTable>

                    @if (_request.Status == RequestStatus.Submitted && _request.ValidationStatus == ValidationStatus.Completed)
                    {
                        <MudCard Class="pa-4 mt-4" Outlined="true">
                            <MudText Typo="Typo.h6" Class="mb-2">Review Request (Reviewer)</MudText>
                            <MudTextField @bind-Value="_reviewerName" Label="Reviewer Name" Required="true" RequiredError="Reviewer name is required" MaxLength="100" Class="mb-2" />
                            <MudTextField @bind-Value="_rejectionReason" Label="Rejection Reason (Required only if rejecting)" Class="mb-3" />
                            <MudStack Row="true">
                                <MudButton Color="Color.Success" Variant="Variant.Filled" Disabled="string.IsNullOrWhiteSpace(_reviewerName) || (_reviewerName.Length > 100)" OnClick="ApproveRequest">Approve</MudButton>
                                <MudButton Color="Color.Error" Variant="Variant.Filled" Disabled="@(string.IsNullOrWhiteSpace(_reviewerName) || string.IsNullOrWhiteSpace(_rejectionReason))" OnClick="RejectRequest">Reject</MudButton>
                            </MudStack>
                        </MudCard>
                    }
                </MudCardContent>
                <MudCardActions>
                    @if (_request.Status == RequestStatus.Draft)
                    {
                        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SubmitRequest">Submit Request</MudButton>
                    }
                    
                    @if (_request.Status == RequestStatus.Approved)
                    {
                        if (!_isFulfilling)
                        {
                            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="() => _isFulfilling = true">Start Fulfillment</MudButton>
                        }
                        else
                        {
                            <MudButton Color="Color.Success" Variant="Variant.Filled" Class="mr-2" OnClick="SaveFulfillment">Complete Fulfillment</MudButton>
                            <MudButton Color="Color.Default" Variant="Variant.Text" OnClick="() => _isFulfilling = false">Cancel</MudButton>
                        }
                    }
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private ReplenishmentRequest? _request;
    private PeriodicTimer? _timer;
    private bool _isFulfilling = false;
    private string _reviewerName = string.Empty;
    private string _rejectionReason = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadRequest();
    }

    private async Task LoadRequest()
    {
        _request = await Http.GetFromJsonAsync<ReplenishmentRequest>($"api/requests/{Id}");

        if (_request?.ValidationStatus == ValidationStatus.Pending)
        {
            StartPolling();
        }
        else
        {
            StopPolling();
        }
    }

    private void StartPolling()
    {
        if (_timer != null) return;
        _timer = new PeriodicTimer(TimeSpan.FromSeconds(2));
        _ = PollValidationStatus();
    }

    private void StopPolling()
    {
        _timer?.Dispose();
        _timer = null;
    }

    private async Task PollValidationStatus()
    {
        while (_timer != null && await _timer.WaitForNextTickAsync())
        {
            await LoadRequest();
            StateHasChanged();
        }
    }

    private async Task SubmitRequest()
    {
        var response = await Http.PostAsync($"api/requests/{Id}/submit", null);
        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add("Request submitted. Validation in progress.", Severity.Info);
            await LoadRequest();
        }
    }

    private async Task ApproveRequest()
    {
        if (string.IsNullOrWhiteSpace(_reviewerName)) return;
        if (_reviewerName.Length > 100)
        {
            Snackbar.Add("Reviewer name cannot exceed 100 characters.", Severity.Error);
            return;
        }

        var payload = new { ReviewerName = _reviewerName };
        var response = await Http.PostAsJsonAsync($"api/requests/{Id}/approve", payload);
        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add("Request approved.", Severity.Success);
            await LoadRequest();
        }
        else
        {
            var errors = await response.Content.ReadFromJsonAsync<Dictionary<string, string[]>>();
            if (errors?.Any() == true)
            {
                var message = string.Join(" ", errors.SelectMany(kvp => kvp.Value));
                Snackbar.Add($"Failed to approve request: {message}", Severity.Error);
            }
            else
            {
                Snackbar.Add("Failed to approve request", Severity.Error);
            }
        }
    }

    private async Task RejectRequest()
    {
        if (string.IsNullOrWhiteSpace(_reviewerName) || string.IsNullOrWhiteSpace(_rejectionReason)) return;

        var payload = new { Reason = _rejectionReason, ReviewerName = _reviewerName };
        var response = await Http.PostAsJsonAsync($"api/requests/{Id}/reject", payload);
        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add("Request rejected.", Severity.Error);
            await LoadRequest();
        }
    }

    private async Task SaveFulfillment()
    {
        // Only include items with a fulfilled quantity > 0
        var fulfilled = _request!.Items
            .Where(i => i.FulfilledQuantity > 0)
            .ToDictionary(i => i.Id, i => i.FulfilledQuantity);

        if (!fulfilled.Any())
        {
            Snackbar.Add("Enter fulfilled quantities for at least one item.", Severity.Warning);
            return;
        }

        // Ensure none exceed requested quantity
        var exceeding = _request.Items.Where(i => i.FulfilledQuantity > i.RequestedQuantity).ToList();
        if (exceeding.Any())
        {
            Snackbar.Add("Fulfilled quantity cannot exceed requested quantity.", Severity.Error);
            return;
        }

        var payload = new { FulfilledQuantities = fulfilled };
        var response = await Http.PostAsJsonAsync($"api/requests/{Id}/fulfill", payload);
        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add("Request fulfilled successfully.", Severity.Success);
            _isFulfilling = false;
            await LoadRequest();
        }
        else
        {
            var errors = await response.Content.ReadFromJsonAsync<Dictionary<string, string[]>>();
            if (errors?.Any() == true)
            {
                var message = string.Join(" ", errors.SelectMany(kvp => kvp.Value));
                Snackbar.Add($"Failed to fulfill request: {message}", Severity.Error);
            }
            else
            {
                Snackbar.Add("Failed to fulfill request", Severity.Error);
            }
        }
    }

    private Color GetStatusColor(RequestStatus status)
    {
        return status switch
        {
            RequestStatus.Draft => Color.Default,
            RequestStatus.Submitted => Color.Info,
            RequestStatus.Approved => Color.Success,
            RequestStatus.Rejected => Color.Error,
            RequestStatus.Fulfilled => Color.Primary,
            _ => Color.Default
        };
    }

    public void Dispose()
    {
        StopPolling();
    }
}
