@page "/"
@inject HttpClient Http
@inject NavigationManager Navigation
@using MudBlazor
@using Mets.Replenishment.UI.Models

<MudText Typo="Typo.h4" GutterBottom="true">Stock Replenishment Requests</MudText>

<MudDataGrid ServerData="LoadServerData" Filterable="true" SortMode="SortMode.Multiple" Groupable="true" T="ReplenishmentRequest">
        <Columns>
            <PropertyColumn Property="x => x.Id" Title="ID" />
            <PropertyColumn Property="x => x.Location" Title="Location" />
            <PropertyColumn Property="x => x.CreatedBy" Title="Created By" />
            <PropertyColumn Property="x => x.ReviewedBy" Title="Reviewed By" />
            <PropertyColumn Property="x => x.Priority" Title="Priority" />
            <PropertyColumn Property="x => x.Status" Title="Status">
                <CellTemplate>
                    <MudChip T="string" Color="@GetStatusColor(context.Item.Status)" Size="Size.Small">@context.Item.Status.ToString()</MudChip>
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ValidationStatus" Title="Validation">
                <CellTemplate>
                    @if (context.Item.ValidationStatus == ValidationStatus.Pending)
                    {
                        <MudProgressCircular Color="Color.Info" Indeterminate="true" Size="Size.Small" />
                    }
                    else
                    {
                        <MudText Typo="Typo.body2">@context.Item.ValidationStatus.ToString()</MudText>
                    }
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.CreatedAt" Title="Created" Format="g" />
            <TemplateColumn Title="Actions">
                <CellTemplate>
                    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => Navigation.NavigateTo($"/request/{context.Item.Id}"))">View</MudButton>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent>
            <MudDataGridPager T="ReplenishmentRequest" />
        </PagerContent>
    </MudDataGrid>

@code {
    private async Task<GridData<ReplenishmentRequest>> LoadServerData(GridState<ReplenishmentRequest> state, CancellationToken cancellationToken)
    {
        var pageNumber = state.Page + 1; // Mud grid pages are zero-based
        var pageSize = state.PageSize;
        
        string? status = null;
        string? priority = null;
        string? location = null;

        foreach (var filter in state.FilterDefinitions)
        {
            if (filter.Value == null) continue;
            
            var field = filter.Column?.PropertyName;
            var valueStr = filter.Value.ToString();
            
            if (field == nameof(ReplenishmentRequest.Status))
                status = valueStr;
            else if (field == nameof(ReplenishmentRequest.Priority))
                priority = valueStr;
            else if (field == nameof(ReplenishmentRequest.Location))
                location = valueStr;
        }

        var uri = $"api/requests?pageNumber={pageNumber}&pageSize={pageSize}";
        if (!string.IsNullOrEmpty(status)) uri += $"&status={Uri.EscapeDataString(status)}";
        if (!string.IsNullOrEmpty(priority)) uri += $"&priority={Uri.EscapeDataString(priority)}";
        if (!string.IsNullOrEmpty(location)) uri += $"&location={Uri.EscapeDataString(location)}";

        var paged = await Http.GetFromJsonAsync<PagedResult<ReplenishmentRequest>>(uri, cancellationToken);
        var items = paged?.Items?.ToList() ?? new List<ReplenishmentRequest>();
        return new GridData<ReplenishmentRequest>() { Items = items, TotalItems = paged?.TotalCount ?? 0 };
    }

    private Color GetStatusColor(RequestStatus status)
    {
        return status switch
        {
            RequestStatus.Draft => Color.Default,
            RequestStatus.Submitted => Color.Info,
            RequestStatus.Approved => Color.Success,
            RequestStatus.Rejected => Color.Error,
            RequestStatus.Fulfilled => Color.Primary,
            _ => Color.Default
        };
    }
}
