@page "/"
@inject HttpClient Http
@inject NavigationManager Navigation

<MudText Typo="Typo.h4" GutterBottom="true">Stock Replenishment Requests</MudText>

@if (_requests == null)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else
{
    <MudDataGrid Items="@_requests" Filterable="true" SortMode="SortMode.Multiple" Groupable="true" T="ReplenishmentRequest">
        <Columns>
            <PropertyColumn Property="x => x.Id" Title="ID" />
            <PropertyColumn Property="x => x.Location" Title="Location" />
            <PropertyColumn Property="x => x.Priority" Title="Priority" />
            <PropertyColumn Property="x => x.Status" Title="Status">
                <CellTemplate>
                    <MudChip T="string" Color="@GetStatusColor(context.Item.Status)" Size="Size.Small">@context.Item.Status.ToString()</MudChip>
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ValidationStatus" Title="Validation">
                <CellTemplate>
                    @if (context.Item.ValidationStatus == ValidationStatus.Pending)
                    {
                        <MudProgressCircular Color="Color.Info" Indeterminate="true" Size="Size.Small" />
                    }
                    else
                    {
                        <MudText Typo="Typo.body2">@context.Item.ValidationStatus.ToString()</MudText>
                    }
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.CreatedAt" Title="Created" Format="g" />
            <TemplateColumn Title="Actions">
                <CellTemplate>
                    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => Navigation.NavigateTo($"/request/{context.Item.Id}"))">View</MudButton>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent>
            <MudDataGridPager T="ReplenishmentRequest" />
        </PagerContent>
    </MudDataGrid>
}

@code {
    private List<ReplenishmentRequest>? _requests;

    protected override async Task OnInitializedAsync()
    {
        _requests = await Http.GetFromJsonAsync<List<ReplenishmentRequest>>("api/requests");
    }

    private Color GetStatusColor(RequestStatus status)
    {
        return status switch
        {
            RequestStatus.Draft => Color.Default,
            RequestStatus.Submitted => Color.Info,
            RequestStatus.Approved => Color.Success,
            RequestStatus.Rejected => Color.Error,
            RequestStatus.Fulfilled => Color.Primary,
            _ => Color.Default
        };
    }
}
